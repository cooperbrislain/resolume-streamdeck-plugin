{
  "$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
  "UUID": "com.cooperbrislain.resolume-grid",
  "Name": "Resolume Grid",
  "Version": "0.1.0.0",
  "Author": "Cooper Brislain",
  "Description": "Live clip thumbnails and triggering for Resolume Arena/Avenue on Stream Deck",
  "Category": "Resolume",
  "CategoryIcon": "imgs/category-icon",
  "CodePath": "dist/plugin.js",
  "Icon": "imgs/plugin-icon",
  "SDKVersion": 2,
  "Software": {
    "MinimumVersion": "6.4"
  },
  "Nodejs": {
    "Version": "20"
  },
  "OS": [
    { "Platform": "mac", "MinimumVersion": "10.15" },
    { "Platform": "windows", "MinimumVersion": "10" }
  ],
  "Actions": [
    {
      "UUID": "com.cooperbrislain.resolume-grid.clip",
      "Name": "Resolume Clip",
      "Icon": "imgs/action-icon",
      "SupportedInMultiActions": false,
      "Controllers": ["Keypad", "Encoder"],
      "Encoder": {
        "layout": "$B1",
        "TriggerDescription": {
          "Rotate": "Scroll clips / layers",
          "Push": "Reset opacity",
          "Touch": "Trigger clip",
          "LongTouch": "Reset viewport"
        }
      },
      "States": [
        {
          "Image": "imgs/action-icon",
          "TitleAlignment": "bottom",
          "FontSize": "10"
        }
      ],
      "PropertyInspectorPath": "property-inspector/index.html"
    }
  ]
}
