# Files excluded from the .streamDeckPlugin bundle.

# Source — only compiled output in dist/ is needed at runtime
src/

# Compiled test artifacts (dist/__tests__ is regenerated by tsc; keep it out of the bundle)
dist/__tests__/

# SVG sources — only the rasterized PNGs ship
imgs/svg/

# Dev / project metadata
.claude/
.git/
.gitignore
.DS_Store
logs/
tsconfig.json
vitest.config.ts
CHANGELOG.md
LICENSE
README.md
package-lock.json

# Nothing inside these matters for the running plugin
*.streamDeckPlugin
